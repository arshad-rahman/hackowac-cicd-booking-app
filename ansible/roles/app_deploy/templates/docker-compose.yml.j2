services:
  db:
    image: postgres:16
    environment:
      POSTGRES_USER: {{ db_user }}
      POSTGRES_PASSWORD: {{ db_password }}
      POSTGRES_DB: {{ db_name }}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ db_user }} -d {{ db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 10
    restart: always

  backend:
    image: {{ backend_image }}
    environment:
      PORT: {{ backend_port }}
      DB_HOST: db
      DB_PORT: 5432
      DB_USER: {{ db_user }}
      DB_PASSWORD: {{ db_password }}
      DB_NAME: {{ db_name }}
    depends_on:
      - db
    restart: always

  frontend:
    image: {{ frontend_image }}
    ports:
      - "{{ frontend_port }}:80"
    depends_on:
      - backend
    restart: always

volumes:
  postgres_data: